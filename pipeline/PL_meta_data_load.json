										"File_name": {
											"value": "@item().name",
											"type": "Expression"
										},
										"Folder_name": "binary"
									}
								}
							],
							"outputs": [
								{
									"referenceName": "DS_STORAGEACCDSTANDARD01_ARCHIVE_WC",
									"type": "DatasetReference",
									"parameters": {
										"file_name": {
											"value": "@concat(\n  'Xlsx/',\n  formatDateTime(pipeline().TriggerTime, 'yyyy'),\n  '/',\n  formatDateTime(pipeline().TriggerTime, 'MM'),\n  '/',\n  formatDateTime(pipeline().TriggerTime, 'dd'),\n  '/',\n  item().name,\n  '_',\n  formatDateTime(pipeline().TriggerTime, 'dd'),\n  '.xlsx'\n)\n",
											"type": "Expression"
										}
									}
								}
							]
						}
					]
				}
			}
		],
